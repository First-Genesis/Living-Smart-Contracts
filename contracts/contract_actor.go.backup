// Handler methods for all contract message types

// handleProposeCollaboration handles collaboration proposal messages
func (ca *ContractActor) handleProposeCollaboration(context actor.Context, msg *ProposeCollaboration) {
	log.Printf("Contract %s: Received collaboration proposal from %s", ca.contract.Address, msg.ProposerAddress)
	
	collaboration := &Collaboration{
		ID:              generateCollaborationID(),
		ProposerAddress: msg.ProposerAddress,
		TargetAddress:   ca.contract.Address,
		ProposalType:    msg.CollaborationType,
		Parameters:      msg.Parameters,
		Status:          CollaborationStatusProposed,
		ProposedAt:      time.Now(),
	}
	
	ca.collaborations[collaboration.ID] = collaboration
	
	// Auto-accept if contract allows or respond with acceptance/rejection
	if ca.shouldAutoAcceptCollaboration(collaboration) {
		ca.acceptCollaboration(context, collaboration)
	}
	
	// Send response to proposer
	context.Send(context.Sender(), &CollaborationResponse{
		CollaborationID: collaboration.ID,
		Status:         collaboration.Status,
		ResponseTime:   time.Now(),
	})
}

// handleAcceptCollaboration handles collaboration acceptance
func (ca *ContractActor) handleAcceptCollaboration(context actor.Context, msg *AcceptCollaboration) {
	collaboration, exists := ca.collaborations[msg.CollaborationID]
	if !exists {
		log.Printf("Contract %s: Unknown collaboration ID: %s", ca.contract.Address, msg.CollaborationID)
		return
	}
	
	collaboration.Status = CollaborationStatusActive
	collaboration.ActivatedAt = time.Now()
	
	log.Printf("Contract %s: Activated collaboration %s", ca.contract.Address, collaboration.ID)
	ca.isDirty = true
}

// handleRejectCollaboration handles collaboration rejection
func (ca *ContractActor) handleRejectCollaboration(context actor.Context, msg *RejectCollaboration) {
	collaboration, exists := ca.collaborations[msg.CollaborationID]
	if !exists {
		log.Printf("Contract %s: Unknown collaboration ID: %s", ca.contract.Address, msg.CollaborationID)
		return
	}
	
	collaboration.Status = CollaborationStatusRejected
	collaboration.RejectedAt = time.Now()
	collaboration.RejectionReason = msg.Reason
	
	log.Printf("Contract %s: Rejected collaboration %s: %s", ca.contract.Address, collaboration.ID, msg.Reason)
	ca.isDirty = true
}

// handleQueryHistory handles historical query requests
func (ca *ContractActor) handleQueryHistory(context actor.Context, msg *QueryHistory) {
	log.Printf("Contract %s: Querying history from %v to %v", ca.contract.Address, msg.StartTime, msg.EndTime)
	
	// Filter execution history by time range
	var filteredHistory []*ContractExecution
	for _, execution := range ca.executionHistory {
		if execution.Timestamp.After(msg.StartTime) && execution.Timestamp.Before(msg.EndTime) {
			filteredHistory = append(filteredHistory, execution)
		}
	}
	
	// Apply additional filters if specified
	if msg.FilterType != "" {
		var finalHistory []*ContractExecution
		for _, execution := range filteredHistory {
			if execution.FunctionName == msg.FilterType {
				finalHistory = append(finalHistory, execution)
			}
		}
		filteredHistory = finalHistory
	}
	
	context.Send(context.Sender(), &HistoryQueryResult{
		ContractAddress: ca.contract.Address,
		Executions:     filteredHistory,
		QueryTime:      time.Now(),
		TotalCount:     len(filteredHistory),
	})
}

// handlePredictFuture handles future prediction requests
func (ca *ContractActor) handlePredictFuture(context actor.Context, msg *PredictFuture) {
	log.Printf("Contract %s: Generating future predictions", ca.contract.Address)
	
	prediction := &FuturePrediction{
		ContractAddress:    ca.contract.Address,
		PredictionType:     msg.PredictionType,
		TimeHorizon:       msg.TimeHorizon,
		PredictedMetrics:  make(map[string]float64),
		ConfidenceScore:   ca.calculatePredictionConfidence(),
		GeneratedAt:       time.Now(),
	}
	
	// Generate predictions based on historical data and contract behavior
	prediction.PredictedMetrics["execution_frequency"] = ca.predictExecutionFrequency(msg.TimeHorizon)
	prediction.PredictedMetrics["gas_usage"] = ca.predictGasUsage(msg.TimeHorizon)
	prediction.PredictedMetrics["success_rate"] = ca.predictSuccessRate(msg.TimeHorizon)
	prediction.PredictedMetrics["adaptation_score"] = ca.predictAdaptationScore(msg.TimeHorizon)
	
	context.Send(context.Sender(), &PredictionResult{
		Prediction: prediction,
		RequestID:  msg.RequestID,
	})
}

// handleSubscribeToEvents handles event subscription requests
func (ca *ContractActor) handleSubscribeToEvents(context actor.Context, msg *SubscribeToEvents) {
	log.Printf("Contract %s: New event subscription from %s", ca.contract.Address, context.Sender().String())
	
	subscription := &EventSubscription{
		SubscriberPID: context.Sender(),
		EventTypes:    msg.EventTypes,
		FilterCriteria: msg.FilterCriteria,
		SubscribedAt:  time.Now(),
	}
	
	ca.eventSubscriptions = append(ca.eventSubscriptions, subscription)
	
	context.Send(context.Sender(), &SubscriptionConfirmation{
		SubscriptionID: len(ca.eventSubscriptions) - 1,
		Status:        "confirmed",
	})
}

// handleEventTriggered handles external event triggers
func (ca *ContractActor) handleEventTriggered(context actor.Context, msg *EventTriggered) {
	log.Printf("Contract %s: External event triggered: %s", ca.contract.Address, msg.EventType)
	
	// Process the event based on contract's reactive behavior
	if ca.shouldReactToEvent(msg.EventType, msg.EventData) {
		execution := &ContractExecution{
			ID:           generateExecutionID(),
			FunctionName: "onEventTriggered",
			Timestamp:    time.Now(),
			Trigger:      "external_event",
			Parameters:   msg.EventData,
		}
		
		ca.executeContractLogic(context, execution)
	}
	
	// Notify event subscribers
	ca.notifyEventSubscribers(msg)
}

// handleEmitEvent handles event emission from contracts
func (ca *ContractActor) handleEmitEvent(context actor.Context, msg *EmitEvent) {
	log.Printf("Contract %s: Emitting event: %s", ca.contract.Address, msg.EventType)
	
	event := &ContractEvent{
		ContractAddress: ca.contract.Address,
		EventType:      msg.EventType,
		EventData:      msg.EventData,
		EmittedAt:      time.Now(),
		BlockHeight:    ca.getCurrentBlockHeight(context),
	}
	
	// Add to contract's event history
	ca.eventHistory = append(ca.eventHistory, event)
	
	// Notify all subscribers
	ca.notifyEventSubscribers(&EventTriggered{
		EventType: msg.EventType,
		EventData: msg.EventData,
		Source:    ca.contract.Address,
	})
	
	// Emit to external event system if configured
	ca.emitContractEvent(context, event)
}

// handleLearnFromExperience handles learning requests
func (ca *ContractActor) handleLearnFromExperience(context actor.Context, msg *LearnFromExperience) {
	log.Printf("Contract %s: Learning from experience data", ca.contract.Address)
	
	// Process experience data to improve contract behavior
	for _, experience := range msg.ExperienceData {
		ca.processExperience(experience)
	}
	
	// Update learning metrics
	ca.contract.LearningRate = ca.calculateLearningRate()
	ca.contract.AdaptationScore = ca.calculateCurrentFitness()
	
	// Trigger behavior analysis if enough new experiences
	if len(msg.ExperienceData) > 5 {
		ca.performBehaviorAnalysis(context)
	}
	
	ca.isDirty = true
}

// handleAnalyzeBehavior handles behavior analysis requests
func (ca *ContractActor) handleAnalyzeBehavior(context actor.Context, msg *AnalyzeBehavior) {
	log.Printf("Contract %s: Performing behavior analysis", ca.contract.Address)
	
	analysis := &BehaviorAnalysis{
		ContractAddress: ca.contract.Address,
		AnalysisType:   msg.AnalysisType,
		TimeWindow:     msg.TimeWindow,
		AnalyzedAt:     time.Now(),
		Metrics:        make(map[string]float64),
		Patterns:       make(map[string]interface{}),
	}
	
	// Perform analysis based on execution history
	analysis.Metrics["execution_efficiency"] = ca.calculateExecutionEfficiency()
	analysis.Metrics["error_rate"] = ca.calculateErrorRate()
	analysis.Metrics["adaptation_trend"] = ca.calculateAdaptationTrend()
	
	// Identify behavioral patterns
	analysis.Patterns["peak_usage_times"] = ca.identifyPeakUsageTimes()
	analysis.Patterns["common_error_patterns"] = ca.identifyErrorPatterns()
	
	context.Send(context.Sender(), &AnalysisResult{
		Analysis:  analysis,
		RequestID: msg.RequestID,
	})
}

// handleQueryContractState handles contract state queries
func (ca *ContractActor) handleQueryContractState(context actor.Context, msg *QueryContractState) {
	log.Printf("Contract %s: State query for: %v", ca.contract.Address, msg.StateKeys)
	
	stateData := make(map[string]interface{})
	
	if len(msg.StateKeys) == 0 {
		// Return full state if no specific keys requested
		stateData["contract"] = ca.contract
		stateData["execution_count"] = ca.executionCount
		stateData["success_count"] = ca.successCount
		stateData["collaborations"] = ca.collaborations
	} else {
		// Return only requested state keys
		for _, key := range msg.StateKeys {
			switch key {
			case "contract":
				stateData[key] = ca.contract
			case "execution_count":
				stateData[key] = ca.executionCount
			case "success_count":
				stateData[key] = ca.successCount
			case "collaborations":
				stateData[key] = ca.collaborations
			case "execution_history":
				stateData[key] = ca.executionHistory
			case "event_history":
				stateData[key] = ca.eventHistory
			}
		}
	}
	
	context.Send(context.Sender(), &StateQueryResult{
		ContractAddress: ca.contract.Address,
		StateData:      stateData,
		QueryTime:      time.Now(),
	})
}

// handleUpdateContractState handles contract state updates
func (ca *ContractActor) handleUpdateContractState(context actor.Context, msg *UpdateContractState) {
	log.Printf("Contract %s: Updating state: %v", ca.contract.Address, msg.StateUpdates)
	
	updateCount := 0
	for key, value := range msg.StateUpdates {
		switch key {
		case "name":
			if name, ok := value.(string); ok {
				ca.contract.Name = name
				updateCount++
			}
		case "description":
			if desc, ok := value.(string); ok {
				ca.contract.Description = desc
				updateCount++
			}
		case "tags":
			if tags, ok := value.([]string); ok {
				ca.contract.Tags = tags
				updateCount++
			}
		case "time_aware":
			if timeAware, ok := value.(bool); ok {
				ca.contract.TimeAware = timeAware
				updateCount++
			}
		case "learning_enabled":
			if learningEnabled, ok := value.(bool); ok {
				ca.contract.LearningEnabled = learningEnabled
				updateCount++
			}
		}
	}
	
	if updateCount > 0 {
		ca.contract.UpdatedAt = time.Now()
		ca.isDirty = true
		
		context.Send(context.Sender(), &StateUpdateResult{
			Success:      true,
			UpdatesApplied: updateCount,
			UpdatedAt:    time.Now(),
		})
	} else {
		context.Send(context.Sender(), &StateUpdateResult{
			Success: false,
			Error:   "No valid state updates provided",
		})
	}
}

// handleUpgradeContract handles contract upgrade requests
func (ca *ContractActor) handleUpgradeContract(context actor.Context, msg *UpgradeContract) {
	log.Printf("Contract %s: Upgrade requested to version %s", ca.contract.Address, msg.NewVersion)
	
	// Validate upgrade conditions
	if !ca.canUpgrade(msg) {
		context.Send(context.Sender(), &UpgradeResult{
			Success: false,
			Error:   "Upgrade conditions not met",
		})
		return
	}
	
	// Perform backup before upgrade
	backup := ca.createContractBackup()
	
	// Apply upgrade
	oldVersion := ca.contract.Version
	ca.contract.Version = msg.NewVersion
	ca.contract.Code = msg.NewCode
	ca.contract.UpdatedAt = time.Now()
	
	// Validate new code
	if !ca.validateContractCode(msg.NewCode) {
		// Rollback on validation failure
		ca.restoreFromBackup(backup)
		context.Send(context.Sender(), &UpgradeResult{
			Success: false,
			Error:   "New contract code validation failed",
		})
		return
	}
	
	// Re-initialize with new code
	ca.initializeContract(context)
	ca.isDirty = true
	
	log.Printf("Contract %s: Successfully upgraded from %s to %s", ca.contract.Address, oldVersion, msg.NewVersion)
	
	context.Send(context.Sender(), &UpgradeResult{
		Success:     true,
		OldVersion:  oldVersion,
		NewVersion:  msg.NewVersion,
		UpgradedAt:  time.Now(),
	})
}
