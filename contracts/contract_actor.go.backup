package contracts

import (
	"context"
	"encoding/json"
	"fmt"
	"log"
	"sync"
	"time"

	"github.com/asynkron/protoactor-go/actor"
	"github.com/google/uuid"
)

// ContractActor represents a living smart contract that can evolve and adapt
type ContractActor struct {
	contract        *Contract
	runtime         *ContractRuntime
	memory          *ContractMemory
	subscriptions   map[uuid.UUID]*EventSubscription
	collaborations  map[uuid.UUID]*ActiveCollaboration
	predictions     map[uuid.UUID]*Prediction
	experienceBuffer []*Experience
	learningEngine   *LearningEngine
	adaptationEngine *AdaptationEngine
	temporalQueries  map[uuid.UUID]*TemporalQuery
	// Performance monitoring
	executionCount   int64
	totalGasUsed     int64
	successCount     int64
	errorCount       int64
	lastActive       time.Time
	
	// State management
	stateMutex       sync.RWMutex
	isDirty          bool
	lastStateCommit  time.Time
	
	// Evolution tracking
	evolutionInProgress bool
	currentEvolution    *EvolutionProcess
	
	// Temporal capabilities
	temporalQueries     map[uuid.UUID]*TemporalQuery
	
	// System references
	registryPID      *actor.PID
	eventStreamPID   *actor.PID
	documentStorePID *actor.PID
	ledgerPID        *actor.PID
}

// EventSubscription represents an active event subscription
type EventSubscription struct {
	ID             uuid.UUID
	Pattern        json.RawMessage
	Callback       string
	FilterCriteria json.RawMessage
	CreatedAt      time.Time
	TriggerCount   int
}

// ActiveCollaboration represents an ongoing collaboration
type ActiveCollaboration struct {
	ID           uuid.UUID
	PartnerPID   *actor.PID
	Type         CollaborationType
	Status       CollaborationStatus
	Terms        json.RawMessage
	StartTime    time.Time
	LastActivity time.Time
	BenefitScore float64
}

// EvolutionProcess tracks an ongoing evolution
type EvolutionProcess struct {
	ID            uuid.UUID
	Type          EvolutionType
	StartTime     time.Time
	Parameters    json.RawMessage
	Progress      float64
	Changes       []string
	FitnessScore  float64
}

// TemporalQuery represents an active temporal query
type TemporalQuery struct {
	ID         uuid.UUID
	Query      json.RawMessage
	StartBlock int64
	EndBlock   int64
	StartTime  time.Time
	Results    []json.RawMessage
}

// NewContractActor creates a new living contract actor
func NewContractActor(contract *Contract, registryPID, eventStreamPID, documentStorePID, ledgerPID *actor.PID) *ContractActor {
	return &ContractActor{
		contract:         contract,
		runtime:          NewContractRuntime(contract),
		memory:           &contract.Memory,
		subscriptions:    make(map[uuid.UUID]*EventSubscription),
		collaborations:   make(map[uuid.UUID]*ActiveCollaboration),
		predictions:      make(map[uuid.UUID]*Prediction),
		experienceBuffer: make([]*Experience, 0, 100), // Buffer last 100 experiences
		learningEngine:   NewLearningEngine(contract),
		adaptationEngine: NewAdaptationEngine(contract),
		temporalQueries:  make(map[uuid.UUID]*TemporalQuery),
		lastActive:       time.Now(),
		registryPID:      registryPID,
		eventStreamPID:   eventStreamPID,
		documentStorePID: documentStorePID,
		ledgerPID:        ledgerPID,
	}
}

// Receive handles incoming messages for the contract actor
func (ca *ContractActor) Receive(context actor.Context) {
	switch msg := context.Message().(type) {
	case *actor.Started:
		ca.handleStarted(context)
	case *actor.Stopping:
		ca.handleStopping(context)
	case *ExecuteContract:
		ca.handleExecuteContract(context, msg)
	case *WakeContract:
		ca.handleWakeContract(context, msg)
	case *SleepContract:
		ca.handleSleepContract(context, msg)
	case *TriggerEvolution:
		ca.handleTriggerEvolution(context, msg)
	case *ProposeCollaboration:
		ca.handleProposeCollaboration(context, msg)
	case *AcceptCollaboration:
		ca.handleAcceptCollaboration(context, msg)
	case *RejectCollaboration:
		ca.handleRejectCollaboration(context, msg)
	case *QueryHistory:
		ca.handleQueryHistory(context, msg)
	case *PredictFuture:
		ca.handlePredictFuture(context, msg)
	case *SubscribeToEvents:
		ca.handleSubscribeToEvents(context, msg)
	case *EventTriggered:
		ca.handleEventTriggered(context, msg)
	case *EmitEvent:
		ca.handleEmitEvent(context, msg)
	case *LearnFromExperience:
		ca.handleLearnFromExperience(context, msg)
	case *AnalyzeBehavior:
		ca.handleAnalyzeBehavior(context, msg)
	case *QueryContractState:
		ca.handleQueryContractState(context, msg)
	case *UpdateContractState:
		ca.handleUpdateContractState(context, msg)
	case *UpgradeContract:
		ca.handleUpgradeContract(context, msg)
	default:
		log.Printf("ContractActor [%s]: Unknown message type: %T", ca.contract.Address, msg)
	}
}

// handleStarted initializes the contract actor
func (ca *ContractActor) handleStarted(context actor.Context) {
	log.Printf("🧬 Living Contract started: %s (%s)", ca.contract.Name, ca.contract.Address)
	
	// Initialize the contract if it's newly deployed
	if ca.contract.Status == ContractStatusDeploying {
		ca.initializeContract(context)
	}
	
	// Set up periodic tasks
	ca.schedulePeriodicTasks(context)
	
	// If this is a temporal contract, start historical analysis
	if ca.contract.TimeAware {
		ca.startTemporalAnalysis(context)
	}
	
	// Restore any existing collaborations
	ca.restoreCollaborations(context)
}

// handleStopping performs cleanup when contract is stopping
func (ca *ContractActor) handleStopping(context actor.Context) {
	log.Printf("🧬 Living Contract stopping: %s (%s)", ca.contract.Name, ca.contract.Address)
	
	// Save current state
	ca.commitState(context)
	
	// Clean up collaborations
	ca.cleanupCollaborations(context)
	
	// Cancel any ongoing evolution
	if ca.evolutionInProgress {
		ca.cancelEvolution(context)
	}
}

// handleExecuteContract executes a contract function
func (ca *ContractActor) handleExecuteContract(context actor.Context, msg *ExecuteContract) {
	ca.lastActive = time.Now()
	ca.executionCount++
	
	// Wake up if sleeping
	if ca.contract.Status == ContractStatusSleeping {
		ca.wakeUp(context, "execution_requested")
	}
	
	// Create execution context
	execution := &ContractExecution{
		ID:              uuid.New(),
		ContractAddress: ca.contract.Address,
		Function:        msg.Function,
		Parameters:      msg.Parameters,
		Caller:          msg.Caller,
		GasLimit:        msg.GasLimit,
		BlockHeight:     ca.getCurrentBlockHeight(context),
		Timestamp:       time.Now(),
		Status:          ExecutionStatusExecuting,
	}
	
	startTime := time.Now()
	
	// Execute the contract function
	result, events, stateChanges, gasUsed, err := ca.runtime.Execute(
		msg.Function, 
		msg.Parameters, 
		msg.Caller, 
		msg.GasLimit,
		ca.memory,
	)
	
	executionTime := time.Since(startTime)
	
	// Update execution results
	execution.GasUsed = gasUsed
	execution.ExecutionTime = executionTime
	execution.Events = events
	execution.StateChanges = stateChanges
	
	if err != nil {
		execution.Status = ExecutionStatusFailed
		execution.Error = err.Error()
		ca.errorCount++
		
		// Learn from the failure
		ca.learnFromFailure(context, execution, err)
	} else {
		execution.Status = ExecutionStatusCompleted
		execution.Result = result
		ca.successCount++
		ca.totalGasUsed += gasUsed
		
		// Learn from the success
		ca.learnFromSuccess(context, execution)
	}
	
	// Update performance metrics
	ca.updatePerformanceMetrics(execution)
	
	// Emit events if any were generated
	for _, event := range events {
		ca.emitContractEvent(context, &event)
	}
	
	// Apply state changes
	if len(stateChanges) > 0 {
		ca.applyStateChanges(context, stateChanges)
	}
	
	// Create learning experience
	experience := &Experience{
		ID:        uuid.New().String(),
		Context:   msg.Parameters,
		Action:    json.RawMessage(fmt.Sprintf(`{"function": "%s", "gas_limit": %d}`, msg.Function, msg.GasLimit)),
		Result:    execution.Result,
		Success:   err == nil,
		Timestamp: time.Now(),
	}
	
	ca.addExperience(experience)
	
	// Check for adaptation triggers
	ca.checkAdaptationTriggers(context, execution)
	
	// Respond with execution results
	context.Respond(&ContractExecuted{
		Execution: execution,
		Success:   err == nil,
		Message:   fmt.Sprintf("Function %s executed successfully", msg.Function),
		Error:     execution.Error,
	})
}

// handleWakeContract wakes up a sleeping contract
func (ca *ContractActor) handleWakeContract(context actor.Context, msg *WakeContract) {
	if ca.contract.Status == ContractStatusSleeping {
		ca.wakeUp(context, msg.Reason)
		
		context.Respond(&ContractAwake{
			ContractAddress: ca.contract.Address,
			Status:          ca.contract.Status,
			Message:         fmt.Sprintf("Contract woken up due to: %s", msg.Reason),
		})
	} else {
		context.Respond(&ContractAwake{
			ContractAddress: ca.contract.Address,
			Status:          ca.contract.Status,
			Message:         "Contract is already awake",
		})
	}
}

// handleSleepContract puts the contract to sleep
func (ca *ContractActor) handleSleepContract(context actor.Context, msg *SleepContract) {
	if ca.contract.Status == ContractStatusActive {
		ca.contract.Status = ContractStatusSleeping
		
		// Schedule wake up if duration is specified
		if msg.Duration > 0 {
			context.SetReceiveTimeout(msg.Duration)
		}
		
		log.Printf("🧬 Contract %s going to sleep", ca.contract.Address)
		
		context.Respond(&ContractSleeping{
			ContractAddress: ca.contract.Address,
			Status:          ca.contract.Status,
			WakeCondition:   msg.Condition,
		})
	}
}

// handleTriggerEvolution starts contract evolution
func (ca *ContractActor) handleTriggerEvolution(context actor.Context, msg *TriggerEvolution) {
	if ca.evolutionInProgress {
		context.Respond(&EvolutionStarted{
			ContractAddress: ca.contract.Address,
			Success:         false,
		})
		return
	}
	
	evolutionID := uuid.New()
	
	ca.currentEvolution = &EvolutionProcess{
		ID:           evolutionID,
		Type:         msg.EvolutionType,
		StartTime:    time.Now(),
		Parameters:   msg.Parameters,
		Progress:     0.0,
		Changes:      make([]string, 0),
		FitnessScore: ca.calculateCurrentFitness(),
	}
	
	ca.evolutionInProgress = true
	ca.contract.Status = ContractStatusEvolving
	
	// Start evolution in background
	go ca.performEvolution(context, msg.EvolutionType, msg.Parameters)
	
	context.Respond(&EvolutionStarted{
		ContractAddress: ca.contract.Address,
		EvolutionID:     evolutionID,
		EstimatedTime:   ca.estimateEvolutionTime(msg.EvolutionType),
		Success:         true,
	})
}

// Helper methods for contract lifecycle

func (ca *ContractActor) initializeContract(context actor.Context) {
	log.Printf("🧬 Initializing contract: %s", ca.contract.Address)
	
	// Initialize memory structures
	if ca.memory.ShortTerm == nil {
		ca.memory.ShortTerm = make(map[string]interface{})
	}
	if ca.memory.LongTerm == nil {
		ca.memory.LongTerm = make(map[string]interface{})
	}
	if ca.memory.Patterns == nil {
		ca.memory.Patterns = make([]MemoryPattern, 0)
	}
	if ca.memory.Experiences == nil {
		ca.memory.Experiences = make([]Experience, 0)
	}
	
	// Set status to active
	ca.contract.Status = ContractStatusActive
	ca.contract.UpdatedAt = time.Now()
	
	// Initialize DNA if this is a morphic contract
	if ca.contract.Type == ContractTypeMorphic {
		ca.initializeDNA()
	}
	
	log.Printf("🧬 Contract initialized successfully: %s", ca.contract.Address)
}

func (ca *ContractActor) schedulePeriodicTasks(context actor.Context) {
	// Schedule state commits every 5 minutes
	context.SetReceiveTimeout(5 * time.Minute)
	
	// Schedule behavior analysis every hour
	go func() {
		ticker := time.NewTicker(1 * time.Hour)
		defer ticker.Stop()
		
		for range ticker.C {
			if ca.contract.Status == ContractStatusActive {
				ca.performBehaviorAnalysis(context)
			}
		}
	}()
}

func (ca *ContractActor) wakeUp(context actor.Context, reason string) {
	ca.contract.Status = ContractStatusActive
	ca.lastActive = time.Now()
	
	log.Printf("🧬 Contract %s waking up: %s", ca.contract.Address, reason)
	
	// Clear any sleep timeout
	context.CancelReceiveTimeout()
	
	// Perform wake-up analysis
	ca.analyzeWakeUpContext(context, reason)
}

func (ca *ContractActor) addExperience(experience *Experience) {
	ca.experienceBuffer = append(ca.experienceBuffer, experience)
	
	// Keep buffer size manageable
	if len(ca.experienceBuffer) > 100 {
		ca.experienceBuffer = ca.experienceBuffer[1:]
	}
	
	// Add to long-term memory
	ca.memory.Experiences = append(ca.memory.Experiences, *experience)
	
	// Trigger learning if we have enough experiences
	if len(ca.experienceBuffer) >= 10 {
		ca.triggerLearning()
	}
}

// ===== MISSING TYPE DEFINITIONS =====

// ActiveCollaboration represents an active collaboration between contracts
type ActiveCollaboration struct {
	ID              string                 `json:"id"`
	PartnerAddress  string                 `json:"partner_address"`
	Type            CollaborationType      `json:"type"`
	Status          CollaborationStatus    `json:"status"`
	ProposedAt      time.Time              `json:"proposed_at"`
	ActivatedAt     *time.Time             `json:"activated_at,omitempty"`
	RejectedAt      *time.Time             `json:"rejected_at,omitempty"`
	RejectionReason string                 `json:"rejection_reason,omitempty"`
	Terms           map[string]interface{} `json:"terms"`
	Benefit         float64                `json:"benefit"`
}

// EventSubscription represents an event subscription
type EventSubscription struct {
	ID             int                    `json:"id"`
	SubscriberPID  interface{}            `json:"subscriber_pid"` // actor.PID
	EventTypes     []string               `json:"event_types"`
	FilterCriteria map[string]interface{} `json:"filter_criteria"`
	SubscribedAt   time.Time              `json:"subscribed_at"`
}

// Various response types
type CollaborationResponse struct {
	CollaborationID string    `json:"collaboration_id"`
	Status         string    `json:"status"`
	ResponseTime   time.Time `json:"response_time"`
}

type SubscriptionConfirmation struct {
	SubscriptionID int       `json:"subscription_id"`
	Status        string    `json:"status"`
	Timestamp     time.Time `json:"timestamp"`
}

type FuturePrediction struct {
	ContractAddress  string             `json:"contract_address"`
	PredictionType   PredictionType     `json:"prediction_type"`
	TimeHorizon      time.Duration      `json:"time_horizon"`
	PredictedMetrics map[string]float64 `json:"predicted_metrics"`
	ConfidenceScore  float64            `json:"confidence_score"`
	GeneratedAt      time.Time          `json:"generated_at"`
}

type PredictionResult struct {
	Prediction *FuturePrediction `json:"prediction"`
	RequestID  string           `json:"request_id"`
	Timestamp  time.Time        `json:"timestamp"`
}

type HistoryQueryResult struct {
	ContractAddress string                `json:"contract_address"`
	Executions     []*ContractExecution  `json:"executions"`
	QueryTime      time.Time             `json:"query_time"`
	TotalCount     int                   `json:"total_count"`
}

type AnalysisResult struct {
	Analysis  *BehaviorAnalysis `json:"analysis"`
	RequestID string           `json:"request_id"`
	Timestamp time.Time        `json:"timestamp"`
}

type StateQueryResult struct {
	ContractAddress string                 `json:"contract_address"`
	StateData      map[string]interface{} `json:"state_data"`
	QueryTime      time.Time              `json:"query_time"`
}

type StateUpdateResult struct {
	Success        bool      `json:"success"`
	UpdatesApplied int       `json:"updates_applied"`
	UpdatedAt      time.Time `json:"updated_at"`
	Error          string    `json:"error,omitempty"`
}

type UpgradeResult struct {
	Success    bool      `json:"success"`
	OldVersion string    `json:"old_version"`
	NewVersion string    `json:"new_version"`
	UpgradedAt time.Time `json:"upgraded_at"`
	Error      string    `json:"error,omitempty"`
}

// Contract backup for upgrades
type ContractBackup struct {
	Version   string    `json:"version"`
	Code      string    `json:"code"`
	State     string    `json:"state"`
	Timestamp time.Time `json:"timestamp"`
}

func (ca *ContractActor) updatePerformanceMetrics(execution *ContractExecution) {
	ca.contract.ExecutionCount++
	
	// Update average gas used
	if ca.contract.ExecutionCount > 0 {
		ca.contract.AverageGasUsed = (ca.contract.AverageGasUsed*(ca.contract.ExecutionCount-1) + execution.GasUsed) / ca.contract.ExecutionCount
	}
	
	// Update success rate
	ca.contract.SuccessRate = float64(ca.successCount) / float64(ca.executionCount)
	
	// Update adaptation score based on performance trends
	ca.updateAdaptationScore()
	
	ca.contract.UpdatedAt = time.Now()
	ca.isDirty = true
}

func (ca *ContractActor) commitState(context actor.Context) {
	if !ca.isDirty {
		return
	}
	
	// Save contract state to document storage
	ca.saveContractToDocumentStore(context)
	
	ca.lastStateCommit = time.Now()
	ca.isDirty = false
}

